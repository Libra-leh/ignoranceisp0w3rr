<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giao diện Trừu tượng Neon</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: #0b011a; /* Màu nền tối sâu */
        }

        .container {
            width: 80%; /* Hoặc tùy chỉnh kích thước bạn muốn */
            max-width: 1000px;
            aspect-ratio: 1 / 1; /* Đảm bảo tỷ lệ khung hình */
            background-color: #0d0016;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        /* SVG nhúng trực tiếp */
        .neon-art {
            width: 100%;
            height: 100%;
        }
    </style>
</head>
<body>

<div class="container">
    <svg class="neon-art" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <linearGradient id="grad-1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#ff1098; stop-opacity:1" /> <stop offset="100%" style="stop-color:#0beaff; stop-opacity:1" /> </linearGradient>
            <linearGradient id="grad-2" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#7f00ff; stop-opacity:1" /> <stop offset="100%" style="stop-color:#14ffd8; stop-opacity:1" /> </linearGradient>
        </defs>

        <rect width="100" height="100" fill="#0d0016"/>

        <g stroke-width="0.3" fill="none">
            <path d="M-10,30 Q15,10 40,30 T90,30 T120,40" stroke="url(#grad-1)" transform="translate(0,-10)"/>
            <path d="M-10,50 Q15,30 40,50 T90,50 T120,60" stroke="url(#grad-2)"/>
            <path d="M-10,70 Q15,50 40,70 T90,70 T120,80" stroke="url(#grad-1)" transform="translate(0,10)"/>
            <path d="M-10,90 Q15,70 40,90 T90,90 T120,100" stroke="url(#grad-2)" transform="translate(0,20)"/>
        </g>

        <g stroke-width="0.3" fill="none">
            <circle cx="20" cy="20" r="10" stroke="url(#grad-1)"/>
            <circle cx="20" cy="20" r="8" stroke="url(#grad-1)" opacity="0.7"/>
            <circle cx="20" cy="20" r="6" stroke="url(#grad-1)" opacity="0.5"/>
            <circle cx="20" cy="20" r="4" stroke="url(#grad-1)" opacity="0.3"/>
            
            <circle cx="80" cy="80" r="10" stroke="url(#grad-2)"/>
            <circle cx="80" cy="80" r="8" stroke="url(#grad-2)" opacity="0.7"/>
            <circle cx="80" cy="80" r="6" stroke="url(#grad-2)" opacity="0.5"/>
            <circle cx="80" cy="80" r="4" stroke="url(#grad-2)" opacity="0.3"/>
        </g>

        <g>
            <rect x="65" y="15" width="20" height="15" fill="none" stroke="url(#grad-1)" stroke-width="0.3" transform="rotate(45,75,22.5)"/>
            <line x1="10" y1="60" x2="30" y2="80" stroke="url(#grad-2)" stroke-width="0.3"/>
            <line x1="10" y1="65" x2="25" y2="80" stroke="url(#grad-2)" stroke-width="0.3" opacity="0.7"/>
            
            <polygon points="40,50 50,40 60,50 50,60" fill="url(#grad-1)" opacity="0.1"/>
        </g>

    </svg>
</div>

</body>
</html>
